{
	"name": "@siftone/server",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts --config ./config.toml",
		"start": "bun run src/index.ts --config ./config.toml",
		"state:restore": "bun run src/index.ts --config ./config.toml --backup",
		"test": "bun test",
		"check": "bun run check:biome && bun run check:shell",
		"check:biome": "biome check .",
		"check:shell": "shellcheck scripts/*.sh",
		"typecheck": "tsc --project tsconfig.json",
		"build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/siftone"
	},
	"dependencies": {
		"commander": "^15.0.0",
		"elysia": "^1.4.29",
		"music-metadata": "^11.14.0",
		"pretty-ms": "^9.3.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@types/bun": "^1.3.14",
		"typescript": "^5.7.2"
	}
}
